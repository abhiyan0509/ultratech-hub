{
    "version": 2,
    "name": "ultratech-dashboard-v7",
    "builds": [
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://abhiyan1021-ultratech-hub.hf.space/api/$1"
        },
        {
            "src": "/(app.js|index.html|styles.css)",
            "dest": "/frontend/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ]
}